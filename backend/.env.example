NODE_ENV=development
PORT=8080

# CORS: put your app URL(s) here, comma separated.
# Example: http://localhost:3000,https://your-app.com
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/duzlemolcer

# JWT secret for signing auth tokens.
# Use a long random value in production.
JWT_SECRET=change-this-long-random-secret
JWT_EXPIRES_IN=7d
